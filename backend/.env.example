# Copy to .env and fill with your own keys. Do not commit .env.

# ─── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=file:./prisma/dev.db
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Gmail OAuth (for "Connect Gmail" and chat notifications) ──────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
# Authorized redirect URI: http://localhost:3001/api/auth/gmail/callback
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3001/api/auth/gmail/callback

# Outbound notification emails — the mailbox that sends alerts
GMAIL_FROM_EMAIL=
GMAIL_MAILER_REFRESH_TOKEN=

# ─── RabbitMQ (optional async workers) ─────────────────────────────────────────
# Skip this for local dev — the backend starts fine without it.
# Start locally with: docker run -p 5672:5672 rabbitmq
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_HEARTBEAT=30
RABBIT_PREFETCH=32
RABBIT_MAX_JOB_ATTEMPTS=5

# ─── Gemini AI (homepage assistant) ────────────────────────────────────────────
# Create at: aistudio.google.com → Get API key
GEMINI_API_KEY=

# ─── Circle Programmable Wallets ───────────────────────────────────────────────
# Create at: console.circle.com → W3S → Developer-Controlled → API Keys
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
