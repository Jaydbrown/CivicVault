# Copy to .env and fill with your own keys. Do not commit .env.

# ─── Arc Testnet (do not change) ───────────────────────────────────────────────
VITE_CHAIN_ID=5042002
VITE_CHAIN_NAME=Arc Testnet
VITE_RPC_URL=https://rpc.testnet.arc.network
VITE_EXPLORER_URL=https://testnet.arcscan.app
VITE_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# ─── Deployed contract addresses (do not change) ───────────────────────────────
VITE_FACTORY_ADDRESS=0x5a9D34264Da36cd05B66Fab80e6e5D6feDC9fDBC
VITE_VIEW_ADDRESS=0x5000F14A757d4488297772b694f18EaF0eC45C81

# ─── Privy ─────────────────────────────────────────────────────────────────────
# Create at: https://dashboard.privy.io → Create app → copy App ID
VITE_PRIVY_APP_ID=

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Create at: https://supabase.com → New project → Settings → API
# Run supabase-scripts/init.sql once in the SQL Editor after creating the project
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Pinata (IPFS for DAO logos & documents) ───────────────────────────────────
# Create at: https://pinata.cloud → API Keys → New Key
VITE_PINATA_JWT=

# ─── Backend URL ───────────────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:3001

# ─── The Graph subgraph (analytics dashboard) ──────────────────────────────────
# After deploying: cd subgraph && npm run deploy:studio
VITE_SUBGRAPH_URL=
